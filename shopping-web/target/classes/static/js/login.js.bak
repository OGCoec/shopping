// === NEW TIANAI UNIVERSAL HANDLING ===
let currentTianaiCaptchaId = "";
let currentTianaiSubType = "";
let tianaiTrackData = null; // Will hold the ImageCaptchaTrack JSON string or plain angle
let tianaiActive = false;

function showTianaiError(message) {
