const PASSWORD_STRENGTH_COLORS = ["#ccc", "red", "orange", "yellowgreen", "green"];
const PASSWORD_STRENGTH_LABELS = ["太短", "极弱", "中等", "强", "极强"];
const PASSWORD_STRENGTH_BASE_WIDTH = 40;
const PASSWORD_STRENGTH_STEP_WIDTH = 30;

